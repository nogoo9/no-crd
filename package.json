{
	"name": "@nogoo9/no-crd",
	"mcpName": "io.github.nogoo9/no-crd",
	"version": "0.5.0",
	"license": "Apache-2.0",
	"description": "Agent-driven, on-demand pod orchestration in Kubernetes (k8s/k3s) without Custom Resource Definitions (CRDs)",
	"author": "eterna2",
	"homepage": "https://nogoo9.github.io/no-crd/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nogoo9/no-crd.git"
	},
	"bugs": {
		"url": "https://github.com/nogoo9/no-crd/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"kubernetes",
		"k8s",
		"k3s",
		"sandbox",
		"spawner",
		"pod-orchestration"
	],
	"files": [
		"dist/**/*.js",
		"dist/ui/index.html",
		"src",
		"themes",
		"templates",
		"deno.json",
		"mcp_servers.json"
	],
	"type": "module",
	"bin": {
		"nocrd9": "dist/cli.js"
	},
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"deno": "./src/index.ts",
			"node": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "bun run src/server-entry.ts",
		"dev:bun": "bun run src/server-entry.ts",
		"dev:deno": "deno run --allow-all src/server-entry.ts",
		"dev:node": "npx tsx src/server-entry.ts",
		"run:bun": "bun dist/server-entry.js",
		"run:deno": "deno run --allow-all dist/server-entry.js",
		"run:node": "node dist/server-entry.js",
		"build": "bun build src/index.ts --outfile dist/index.js --target node --minify && bun build src/server-entry.ts --outfile dist/server-entry.js --target node --minify && bun build src/cli.ts --outfile dist/cli.js --target node --minify && bun run scripts/build-ui.ts",
		"prepublishOnly": "bun run build",
		"setup": "bun run src/cli.ts",
		"lint": "biome check . && bun run scripts/check-imports.ts",
		"format": "biome check --write --unsafe .",
		"check": "biome check --write --unsafe .",
		"typecheck": "tsc --noEmit",
		"inspect": "bun run build && TRANSPORT=stdio bunx @modelcontextprotocol/inspector bun run dist/server-entry.js",
		"test": "bun test src/**/*.test.ts src/*.test.ts",
		"test:lifecycle": "bun run scripts/test-lifecycle.ts",
		"test:mcp-cli": "bun run scripts/test-mcp-cli.ts",
		"test:antigravity": "bun run scripts/run-antigravity-test.ts",
		"update:permissions": "bun run scripts/update-docs.ts",
		"build:docs": "bun run update:permissions && nice -n 19 env UV_THREADPOOL_SIZE=2 NODE_OPTIONS='--max-old-space-size=1536' typedoc",
		"docs:dev": "bun run build:docs && nice -n 19 env UV_THREADPOOL_SIZE=2 NODE_OPTIONS='--max-old-space-size=1536' vitepress dev docs --port 5183",
		"docs:build": "bun run build:docs && nice -n 19 env UV_THREADPOOL_SIZE=2 NODE_OPTIONS='--max-old-space-size=1536' vitepress build docs"
	},
	"dependencies": {
		"@fastify/http-proxy": "^11.4.4",
		"@fastify/static": "^9.1.3",
		"@kubernetes/client-node": "^1.4.0",
		"@logtape/logtape": "^0.8.2",
		"@modelcontextprotocol/ext-apps": "^1.7.2",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"fastify": "^5.8.5",
		"js-yaml": "^4.1.0",
		"jsonpath-plus": "^10.4.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "latest",
		"mermaid": "^11.15.0",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.11.0",
		"typedoc-vitepress-theme": "^1.1.2",
		"typescript": "^5.9.3",
		"vitepress": "^1.6.4",
		"vitepress-plugin-mermaid": "^2.0.17"
	},
	"overrides": {
		"vite": "^6.4.2",
		"esbuild": "^0.25.0"
	}
}
